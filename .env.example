# Local dev — /backend proxy keeps JWT cookies on localhost:3000
NEXT_PUBLIC_API_BASE_URL=/backend
API_INTERNAL_URL=http://localhost:5000

# Production (Vercel) — same pattern:
# NEXT_PUBLIC_API_BASE_URL=/backend
# API_INTERNAL_URL=https://server-rho-steel-72.vercel.app
# BETTER_AUTH_URL=https://studynook-psi.vercel.app
# NEXTAUTH_URL=https://studynook-psi.vercel.app

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MONGODB_URI=
DB_NAME=StudyNook
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google Cloud Console → OAuth client → Authorized redirect URIs:
# http://localhost:3000/api/auth/callback/google
# Authorized JavaScript origins: http://localhost:3000
